# Gemini API key. EmptyでもUI/Google連携は動きますが、AI対話は詳細生成できません。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional. 設定すると memories.embedding をGemini埋め込みで作ります。
# 未設定の場合は無料のhash-fallback埋め込みでpgvectorパイプラインを動かします。
# 例: gemini-embedding-001
GEMINI_EMBEDDING_MODEL=

# Supabase is optional. If empty, app still runs but memory/profile persistence is disabled.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Never put SUPABASE_SERVICE_ROLE_KEY in Flutter or GitHub.
